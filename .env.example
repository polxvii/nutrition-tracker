# Copy this file to .env and fill in your values.

# --- Supabase (client-side — needs the VITE_ prefix) ---
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Stage 2: AI photo logging (SERVER-SIDE — no VITE_ prefix!) ---
# Anthropic API key used by the /api/analyze serverless function.
# The VITE_ prefix is intentionally absent so this key is NEVER bundled into
# the browser. Local dev reads it here; production reads it from Cloudflare
# Pages → Settings → Environment variables (add it there too, as a secret).
# Get a key at https://console.anthropic.com → Settings → API keys
ANTHROPIC_API_KEY=sk-ant-...
# Optional — override the vision model (default: claude-sonnet-5)
# ANTHROPIC_MODEL=claude-sonnet-5
