# Copy this file to .env and fill in your values.

# --- Supabase (client-side — needs the VITE_ prefix) ---
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Stage 2: AI photo logging (SERVER-SIDE — no VITE_ prefix!) ---
# Google Gemini API key used by the /api/analyze serverless function (free tier).
# The VITE_ prefix is intentionally absent so this key is NEVER bundled into
# the browser. Local dev reads it here; production reads it from Cloudflare
# Pages → Settings → Environment variables (add it there too, as a secret).
# Get a FREE key at https://aistudio.google.com/apikey (no credit card needed)
GEMINI_API_KEY=AIza...
# Optional — override the vision model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.0-flash
